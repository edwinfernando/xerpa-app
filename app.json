{
  "expo": {
    "name": "XERPA",
    "slug": "xerpa-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.xerpa-app"
    },
    "android": {
      "userInterfaceStyle": "dark",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.xerpaapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-system-ui",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "XERPA necesita tu ubicación para personalizar tu plan de entrenamiento según tu clima y zona."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00F0FF",
          "sounds": []
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "datePicker": {
              "windowBackground": { "light": "#FFFFFF", "dark": "#1C1C1E" },
              "textColorPrimary": { "light": "#000000", "dark": "#FFFFFF" },
              "textColorSecondary": { "light": "#666666", "dark": "#8E8E93" },
              "colorAccent": { "light": "#00D2FF", "dark": "#00D2FF" },
              "colorControlActivated": { "light": "#00D2FF", "dark": "#00D2FF" }
            }
          }
        }
      ]
    ],
    "scheme": "xerpa"
  }
}
