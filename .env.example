# Google Maps API Key (requerido para "Elegir ubicación en mapa" en Android)
# Obtener en: https://console.cloud.google.com/apis/credentials
# 1. Crear proyecto → Habilitar "Maps SDK for Android"
# 2. Create Credentials → API Key
# 3. Copiar la key aquí
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Strava OAuth (requerido para "Conectar con Strava" en Integraciones)
# Obtener en: https://www.strava.com/settings/api
# 1. Crear aplicación → Authorization Callback Domain: xerpa
# 2. Copiar Client ID aquí
EXPO_PUBLIC_STRAVA_CLIENT_ID=
